# Firebase web config — copy this file to `.env.local` and paste your values.
# These are NOT secrets (they ship to the browser); Firestore rules protect data.
# Get them from: Firebase Console → Project settings → Your apps → SDK setup → Config.
# See FIREBASE_SETUP.md for step-by-step instructions.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Cloudinary image uploads — see CLOUDINARY_SETUP.md.
# cloud name from your dashboard; preset must be an UNSIGNED upload preset.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
