rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Single dashboard doc is open while /admin has no login (current phase).
    // When auth is added, change the dashboards write rule to:
    //   allow write: if request.auth != null;
    match /dashboards/{docId} {
      allow read, write: if true;
    }
    // Everything else is locked down.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
